<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260226120000-1" author="jhipster">
        <createTable tableName="osztalekfizetesi_kozgyulesek_dokumentum">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="dokumentum_tipusa" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="dokumentum_nev" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="fajl_nev" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="dokumentum_url" type="varchar(1000)"/>
            <column name="dokumentum_azonosito" type="varchar(50)"/>
            <column name="feltoltes_ideje" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="kozgyules_id" type="bigint"/>
        </createTable>
    </changeSet>

    <changeSet id="20260226120000-2" author="jhipster">
        <addForeignKeyConstraint
            baseColumnNames="kozgyules_id"
            baseTableName="osztalekfizetesi_kozgyulesek_dokumentum"
            constraintName="fk_osztalekfizetesi_kozgyulesek_dokumentum_kozgyules_id"
            referencedColumnNames="id"
            referencedTableName="osztalekfizetesi_kozgyulesek"/>
    </changeSet>

</databaseChangeLog>
