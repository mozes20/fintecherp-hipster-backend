<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Update entity Timesheetek - add user_login, ora_mennyiseg, megjegyzes columns.
    -->
    <changeSet id="20260120000001-1" author="jhipster">
        <addColumn tableName="timesheetek">
            <column name="user_login" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <addColumn tableName="timesheetek">
            <column name="ora_mennyiseg" type="integer">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <addColumn tableName="timesheetek">
            <column name="megjegyzes" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="20260120000001-2" author="jhipster">
        <addNotNullConstraint tableName="timesheetek" columnName="user_login" columnDataType="varchar(255)"/>
    </changeSet>

    <changeSet id="20260120000001-3" author="jhipster">
        <createIndex tableName="timesheetek" indexName="idx_timesheetek_user_login">
            <column name="user_login"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
